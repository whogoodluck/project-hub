{
  "name": "project-hub",
  "version": "1.0.0",
  "description": "A Real-Time Client Project Dashboard with Role-Based Access &amp; Live Activity Feed",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=production tsx dist/index.js",
    "dev": "NODE_ENV=development tsx --watch src/index.ts",
    "build": "tsc",
    "build:frontend": "cd ./web && npm install && npm run build",
    "build:backend": "npm run build",
    "build:all": "npm run build:frontend && npm run build:backend",
    "lint": "eslint .",
    "format": "prettier --write .",
    "studio": "npx prisma studio",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whogoodluck/project-hub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/whogoodluck/project-hub/issues"
  },
  "homepage": "https://github.com/whogoodluck/project-hub#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
